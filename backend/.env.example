# ─── POS Backend — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your actual values.
# DO NOT commit the actual .env file to version control.

# ─── Database ───────────────────────────────────────────────────────────────
# Local development defaults (XAMPP / WAMP / Laravel Herd):
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=multitenant_pos

# Production example (cPanel / shared hosting):
# DB_HOST=sql101.cpanelfree.com
# DB_USER=your_db_username
# DB_PASS=your_db_password
# DB_NAME=your_db_name

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars
JWT_EXPIRE=8h
